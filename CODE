#include <Arduino.h>
#include <Keypad.h>
#include <U8g2lib.h>
#include <Servo.h>
#include <Wire.h>

// --- SYSTEM SETTINGS ---
const String MASTER_PIN = "1234";    // Change this to your desired 4-digit lock code
const int LATCH_DELAY   = 5000;    // Time (in milliseconds) the door stays unlocked

// Servo Latch Positions
const int LATCH_LOCKED   = 0;      // Angle when locked
const int LATCH_UNLOCKED = 90;     // Angle when unlocked

// --- NATIVE ESP8266 PIN CONFIGURATION ---
const int SERVO_PIN = D4;          // SG90 Servo Signal Pin

// 4x3 Matrix Keypad Setup
const byte ROWS = 4; 
const byte COLS = 3; 
char keys[ROWS][COLS] = {
  {'1','2','3'},
  {'4','5','6'},
  {'7','8','9'},
  {'*','0','#'}
};

// Explicit NodeMCU Pin Layout to avoid boot conflicts
byte rowPins[ROWS] = {D3, D5, D6, D7}; 
byte colPins[COLS] = {D0, D8, D10}; // Note: D10 is the RX pin on most NodeMCUs

// --- HARDWARE OBJECTS ---
Keypad customKeypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);
Servo latchServo;

// Using Hardware I2C: D2 is SDA, D1 is SCL by default on ESP8266
U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, /* reset=*/ U8X8_PIN_NONE);

// --- STATE MANAGEMENT ---
String userBuffer = "";
bool deviceLocked = true;
unsigned long unlockTimestamp = 0;

// Forward Declarations
void renderUI(String heading, String mask);
void activateLock();
void activateUnlock();

void setup() {
  Serial.begin(115200);
  delay(200); // Allow hardware voltages to stabilize
  Serial.println("\n[SYSTEM] Booting Smart Digital Lock...");

  // Initialize Screen
  u8g2.begin();
  
  // Initialize Servo
  latchServo.attach(SERVO_PIN);
  
  // Force Secure State on Power Up
  activateLock();
}

void loop() {
  char pressedKey = customKeypad.getKey();
  
  // Non-blocking Auto-Relock Monitor
  if (!deviceLocked && (millis() - unlockTimestamp >= LATCH_DELAY)) {
    activateLock();
  }

  if (pressedKey) {
    Serial.print("[KEYPRESS]: ");
    Serial.println(pressedKey);

    // '#' Clear Key
    if (pressedKey == '#') {
      userBuffer = "";
      if (deviceLocked) renderUI("ENTER PIN", "");
    } 
    // '*' Submit Key
    else if (pressedKey == '*') {
      if (deviceLocked) {
        if (userBuffer == MASTER_PIN) {
          activateUnlock();
        } else {
          renderUI("INVALID PIN!", "");
          delay(2000); // Temporary pause for visual feedback
          userBuffer = "";
          renderUI("ENTER PIN", "");
        }
      }
    } 
    // Standard Digit Input (Max 4 digits)
    else if (userBuffer.length() < 4 && deviceLocked) {
      userBuffer += pressedKey;
      
      // Build masking string dynamically
      String secureMask = "";
      for (size_t i = 0; i < userBuffer.length(); i++) {
        secureMask += "*";
      }
      renderUI("ENTER PIN", secureMask);
    }
  }
}

// --- CORE ACTIONS ---

void activateLock() {
  deviceLocked = true;
  latchServo.write(LATCH_LOCKED);
  userBuffer = "";
  renderUI("SYSTEM LOCKED", "");
  Serial.println("[STATUS] Secure Mode Active.");
}

void activateUnlock() {
  deviceLocked = false;
  latchServo.write(LATCH_UNLOCKED);
  unlockTimestamp = millis(); // Benchmark time for non-blocking auto-relock
  renderUI("ACCESS GRANTED", "UNLOCKED");
  Serial.println("[STATUS] Lock Disengaged.");
}

// UI Render Engine (Optimized for SSD1306)
void renderUI(String heading, String mask) {
  u8g2.clearBuffer();
  
  // Draw sleek outer layout frame
  u8g2.drawFrame(0, 0, 128, 64);
  u8g2.drawFrame(2, 2, 124, 60);
  
  // Output Top Header String (Centered)
  u8g2.setFont(u8g2_font_helvB08_tr);
  int headWidth = u8g2.getStrWidth(heading.c_str());
  u8g2.drawStr((128 - headWidth) / 2, 26, heading.c_str());
  
  // Output Password Mask String (Centered)
  u8g2.setFont(u8g2_font_helvB14_tr);
  int maskWidth = u8g2.getStrWidth(mask.c_str());
  u8g2.drawStr((128 - maskWidth) / 2, 52, mask.c_str());
  
  u8g2.sendBuffer();
}
